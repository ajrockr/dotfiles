#!/bin/bash

NOTES_DIR="$HOME/notes"

if [ ! -d "$NOTES_DIR" ]; then
    echo "Notes directory not found: $NOTES_DIR"
    exit 1
fi

if [ -n "$1" ]; then
    FILE="$NOTES_DIR/$1.md"
else
    FILE=$(find "$NOTES_DIR" -maxdepth 1 -type f -printf "%f\n" \
        | sort \
        | fzf)

    [ -z "$FILE" ] && exit 0

    FILE="$NOTES_DIR/$FILE"
fi

if [ ! -f "$FILE" ]; then
    echo "Note not found: $FILE"
    exit 1
fi

read -rp "Delete $(basename "$FILE")? [y/N] " CONFIRM

case "$CONFIRM" in
    y|Y|yes|YES)
        rm -- "$FILE"
        echo "Note deleted."
        ;;
    *)
        echo "Cancelled."
        ;;
esac

